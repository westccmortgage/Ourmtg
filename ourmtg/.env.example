# ── OurMTG front-end (Vite) — client env. Only VITE_* vars reach the browser. ──
# Point these at the SAME Supabase project as GRCRM (see docs/OURMTG_GATEWAY.md).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL for the portal gateway functions. Leave blank in production (same origin →
# /.netlify/functions). Set only when running `vite dev` against a remote deploy.
VITE_API_BASE=

# Branding / compliance surface (shown in footer). Defaults are baked into
# src/lib/config.js — set these only to override.
VITE_COMPANY_NAME=West Coast Capital Mortgage Inc.
VITE_LO_NAME=Anatoliy
VITE_NMLS_COMPANY=2817729
VITE_NMLS_LO=
VITE_OFFICE_PHONE=310-654-1577
VITE_LO_PHONE=310-686-5053
VITE_CONTACT_EMAIL=westccmortgage@gmail.com

# ── Server-side function env (NOT VITE_*, set in Netlify) ──
# Point the Supabase vars at the SAME project as GRCRM (see docs/OURMTG_GATEWAY.md).
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE=
# SUPABASE_ANON_KEY=
# RESEND_PLATFORM_KEY=
# OURMTG_URL=https://ourmtg.com
# lead-submit proxy → GRCRM lead-inbound webhook (token stays server-side, never in the bundle):
# LEAD_INBOUND_URL=https://grcrm.com/.netlify/functions/lead-inbound
# LEAD_INBOUND_TOKEN=your-lead-source-token

# ── Platform administration (Phase 1A #1) ──
# REQUIRED for platform administration: creating the first/manual loan file and editing
# site-wide settings. ONLY these verified JWT emails receive that authority; loan-file
# ownership does NOT expand the allowlist. Empty/unset = no one (fail-closed).
# OURMTG_ADMIN_EMAILS=admin@ourmtg.com,owner@westccmortgage.com

# ── Cron authorization for the sync-loan-file projector (Phase 1A Blocker B) ──
# OURMTG_CRON_SECRET is the ONLY thing that authorizes a scheduled run. An authenticated
# scheduler MUST send:  Authorization: Bearer <OURMTG_CRON_SECRET>. Constant-time compared;
# never read from the query string; never logged. Fail-closed if unset. Treat like a password.
# OURMTG_CRON_SECRET=long-random-string

# ── Public lead-submit abuse protection (Phase 1A Blocker C; optional tunables) ──
# Best-effort in-process limiter keyed by a salted hash of IP+UA (raw IP never stored for
# rate limiting). LEAD_RATE_MAX submissions per LEAD_RATE_WINDOW_MS window.
# LEAD_RATE_MAX=5
# LEAD_RATE_WINDOW_MS=60000
# Per-deploy salt for the rate-limit fingerprint (makes digests non-reversible across deploys).
# OURMTG_FINGERPRINT_SALT=random-per-deploy-string

# ── Phase 1C task pilot — SERVER-SIDE feature flags (EXT-10; FAIL-CLOSED) ──
# These are the ONLY switches that authorize the task-pilot backend. They are read server-side
# in Netlify functions; only the literal strings "true" or "1" enable a flag — anything else
# (missing, "false", "TRUE", "yes") is OFF. Leave unset in production until the org backfill
# (EXT-13) reports zero unprovisioned loan files.
#   • FF_TASK_PILOT           — borrower task list/detail/transition + task-linked upload.
#   • FF_LOAN_TEAM_TASK_PILOT — loan-team task create + review.
# FF_TASK_PILOT=false
# FF_LOAN_TEAM_TASK_PILOT=false
#
# NOTE: VITE_FF_* variables (if present) are PRESENTATION-ONLY. They toggle UI affordances in the
# browser bundle and NEVER authorize backend use — the server ignores them entirely.
# VITE_FF_TASK_PILOT=false
# VITE_FF_LOAN_TEAM_TASK_PILOT=false
