# ── OurMTG front-end (Vite) — client env. Only VITE_* vars reach the browser. ──
# Point these at the SAME Supabase project as GRCRM (see docs/OURMTG_GATEWAY.md).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL for the portal gateway functions. Leave blank in production (same origin →
# /.netlify/functions). Set only when running `vite dev` against a remote deploy.
VITE_API_BASE=

# Branding / compliance surface (shown in footer). Defaults are baked into
# src/lib/config.js — set these only to override.
VITE_COMPANY_NAME=West Coast Capital Mortgage Inc.
VITE_LO_NAME=Anatoliy
VITE_NMLS_COMPANY=2817729
VITE_NMLS_LO=
VITE_OFFICE_PHONE=310-654-1577
VITE_LO_PHONE=310-686-5053
VITE_CONTACT_EMAIL=westccmortgage@gmail.com

# ── Server-side function env (NOT VITE_*, set in Netlify) ──
# Point the Supabase vars at the SAME project as GRCRM (see docs/OURMTG_GATEWAY.md).
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE=
# SUPABASE_ANON_KEY=
# RESEND_PLATFORM_KEY=
# OURMTG_URL=https://ourmtg.com
# lead-submit proxy → GRCRM lead-inbound webhook (token stays server-side, never in the bundle):
# LEAD_INBOUND_URL=https://grcrm.com/.netlify/functions/lead-inbound
# LEAD_INBOUND_TOKEN=your-lead-source-token

# ── Platform administration (Phase 1A #1) ──
# REQUIRED to edit site-wide settings (live rate, loan programs, home copy). ONLY these
# emails may write site_settings; loan-file ownership does NOT grant this. Empty = no one.
# OURMTG_ADMIN_EMAILS=admin@ourmtg.com,owner@westccmortgage.com

# ── Cron authorization for the sync-loan-file projector (Phase 1A #4) ──
# CRON_SECRET is the DEFAULT, preferred authorization: an authenticated scheduler must send
# `x-cron-secret: <CRON_SECRET>` (or ?cron_secret=). Treat it like a password.
# CRON_SECRET=long-random-string
# Set to true ONLY if you rely on Netlify's built-in scheduler and accept its x-netlify-event
# header as proof of origin. Default (unset/false) = header alone does NOT authorize.
# CRON_ALLOW_NETLIFY_SCHEDULE=false

# ── Public lead-submit rate limiting (Phase 1A #3; optional tunables) ──
# Per-IP best-effort limiter: LEAD_RATE_MAX submissions per LEAD_RATE_WINDOW_MS window.
# LEAD_RATE_MAX=5
# LEAD_RATE_WINDOW_MS=60000
